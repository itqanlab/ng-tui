{
  "name": "@ng-tui/cli",
  "version": "0.0.1",
  "description": "CLI scaffolding tool: ng-tui new, generate, serve, build",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ng-tui": "./bin/ng-tui.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@ng-tui/common": "workspace:*",
    "@ng-tui/compiler": "workspace:*",
    "@ng-tui/core": "workspace:*",
    "@ng-tui/platform-terminal": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.2"
  }
}
